# Prometheus Configuration
VITE_PROMETHEUS_BASE_URL=/prometheus
VITE_PROMETHEUS_PROXY_TARGET=http://localhost:9090
VITE_PROMETHEUS_RANGE_STEP=30s
VITE_PROMETHEUS_PLATFORM=windows

# Backend Server
PORT=7777

# Notes:
# - VITE_PROMETHEUS_PLATFORM: Plataforma del sistema ('windows' o 'linux')
# - VITE_PROMETHEUS_PROXY_TARGET: URL base de Prometheus
#   Si Prometheus corre en Docker: http://host.docker.internal:9090
# - VITE_PROMETHEUS_RANGE_STEP: Intervalo de muestreo de datos históricos
# - PORT: Puerto del servidor backend (default: 7777)
#
# Copia este archivo a .env y ajusta los valores según tu entorno:
# cp .env.example .env